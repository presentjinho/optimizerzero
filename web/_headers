/*
  X-Robots-Tag: noindex, nofollow, noarchive
  X-Content-Type-Options: nosniff
  Referrer-Policy: no-referrer
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'wasm-unsafe-eval'; style-src 'self'; img-src 'self' blob: data:; connect-src 'self'; worker-src 'self' blob:; object-src 'none'; base-uri 'self'; form-action 'none'; frame-ancestors 'none'
  Cross-Origin-Opener-Policy: same-origin

/
  Content-Type: text/html; charset=utf-8

/index.html
  Content-Type: text/html; charset=utf-8

/styles.css
  Content-Type: text/css; charset=utf-8

/app.js
  Content-Type: application/javascript; charset=utf-8

/optimize-core.js
  Content-Type: application/javascript; charset=utf-8

/worker.js
  Content-Type: application/javascript; charset=utf-8

/vendor/jszip.min.js
  Content-Type: application/javascript; charset=utf-8

/vendor/pdf-lib.min.js
  Content-Type: application/javascript; charset=utf-8

/vendor/pdfjs/pdf.min.js
  Content-Type: application/javascript; charset=utf-8

/vendor/pdfjs/pdf.worker.min.js
  Content-Type: application/javascript; charset=utf-8

/README.md
  Content-Type: text/markdown; charset=utf-8

/PRIVACY.md
  Content-Type: text/markdown; charset=utf-8

/manifest.webmanifest
  Content-Type: application/manifest+json; charset=utf-8

/service-worker.js
  Content-Type: application/javascript; charset=utf-8
  Cache-Control: no-cache
